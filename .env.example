# ═══════════════════════════════════════════════════════════════════
# RegPlatform 环境变量配置
# 复制为 .env 并修改
# ═══════════════════════════════════════════════════════════════════

# ── 服务器 ──
PORT=8000
GIN_MODE=debug
DEV_MODE=true

# ── 数据库 ──
DATABASE_URL=postgres://postgres:postgres@localhost:5432/regplatform?sslmode=disable

# ── JWT ──
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRE_HOURS=72

# ── 管理员（可选，为空则第一个注册的用户自动成为管理员）──
ADMIN_USERNAME=

# ── SSO 对接（可选，用于外部系统集成）──
SSO_SECRET=

# ── Redis（可选，为空则使用内存缓存）──
REDIS_URL=

# ═══════════════════════════════════════════════════════════════════
# 以下配置也可在管理后台「系统设置」中配置，持久化到数据库
# ═══════════════════════════════════════════════════════════════════

# ── YYDS Mail 邮箱 ──
# YYDSMAIL_API_KEY=your-yydsmail-key
# 推荐填写根域名；即使误填到 /v1，服务端也会自动归一化。
# YYDSMAIL_BASE_URL=https://maliapi.215.im

# ── 验证码求解 ──
# TURNSTILE_SOLVER_URL=http://127.0.0.1:5072
# CF_BYPASS_SOLVER_URL=http://127.0.0.1:5073
# YESCAPTCHA_KEY=

# ── Camoufox 浏览器注册（留空使用 HTTP 模式）──
# CAMOUFOX_REG_URL=

# ── 代理 ──
# DEFAULT_PROXY=
# KOOKEEY_API=

# ── 限制 ──
# MAX_THREADS_PER_USER=16
# MAX_TARGET_PER_TASK=1000
